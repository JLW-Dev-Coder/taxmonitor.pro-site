{
  "_description": "Canonical settings.local.json template for all VLP ecosystem repos. Copy to .claude/settings.local.json and customize per repo.",
  "_usage": "Remove _description and _usage keys when copying to settings.local.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(mkdir:*)",
      "Bash(copy:*)",
      "Bash(move:*)",
      "Bash(dir:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Read(**)"
    ]
  },
  "autoApprove": [
    "Write",
    "Edit",
    "Create"
  ],
  "autoApprovePatterns": [
    ".claude/**",
    "**/*.md",
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.css",
    "**/*.html",
    "**/*.js",
    "**/*.mjs"
  ],
  "deny": [
    "Bash(rm -rf *)",
    "Bash(del /s *)",
    "Bash(curl *)",
    "Bash(wget *)",
    "Bash(wrangler deploy *)",
    "Bash(wrangler publish *)"
  ],
  "maxTurns": 30
}
